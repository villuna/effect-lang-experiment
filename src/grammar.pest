WHITESPACE = _{ " " | "\t" | "\n" }

ident = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }

number       = ${ int ~ decimal_part? ~ exponent? }
decimal_part = @{ ("." ~ ASCII_DIGIT+) }
exponent     = @{ (^"e" ~ int) }
int          = @{ ASCII_DIGIT+ }

string       = ${ "\"" ~ string_inner ~ "\"" }
string_inner = @{ string_char* }
string_char  = _{ "\\" ~ escape_char | !("\"") ~ ANY }
escape_char  = _{ "\"" | "\\" }

// TODO parameters
function_def = { "fun" ~ ident ~ "(" ~ ")" ~ block }

block = { "{" ~ statement_list ~ "}" }

unit           = { "()" }
bool           = { "true" | "false" }
statement_list = { (statement ~ ";")* ~ expression? }
statement      = { variable_def | expression }
atom           = {
    unit
  | number
  | string
  | bool
  | function_call
  | ident
  | block
  | "(" ~ expression ~ ")"
}
function_call  = { ident ~ "(" ~ (expression ~ ("," ~ expression)*)? ~ ")" }

expression =  { atom ~ (bin_op ~ atom)* }
bin_op     = _{ add | sub | mult | div | eq | neq | gt | geq | lt | leq }
add        =  { "+" }
sub        =  { "-" }
mult       =  { "*" }
div        =  { "/" }
eq         =  { "==" }
neq        =  { "!=" }
gt         =  { ">" }
geq        =  { ">=" }
lt         =  { "<" }
leq        =  { "<=" }

variable_def = { "let" ~ ident ~ "=" ~ expression }

program = { SOI ~ function_def* ~ EOI }
