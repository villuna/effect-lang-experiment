program = { SOI ~ function_def* ~ EOI }

// Basic components (ints, strings etc)
WHITESPACE = _{ " " | "\t" | "\n" }

ident = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }

number       = ${ int ~ decimal_part? ~ exponent? }
decimal_part = @{ ("." ~ ASCII_DIGIT+) }
exponent     = @{ (^"e" ~ int) }
int          = @{ ASCII_DIGIT+ }

string       = ${ "\"" ~ string_inner ~ "\"" }
string_inner = @{ string_char* }
string_char  = _{ "\\" ~ escape_char | !("\"") ~ ANY }
escape_char  = _{ "\"" | "\\" }

// Grammar for statements and expressions

block = { "{" ~ statement_list ~ "}" }

unit           = { "()" }
bool           = { "true" | "false" }
statement_list = { (statement ~ ";")* ~ expression? }
statement      = { variable_def | expression }
primary        = {
    unit
  | number
  | string
  | bool
  | function_call
  | conditional
  | block
  | "(" ~ expression ~ ")"
  | ident
}
function_call  = { ident ~ "(" ~ (expression ~ ("," ~ expression)*)? ~ ")" }

conditional = { "if" ~ expression ~ block ~ ("else" ~ (conditional | block))? }

expression =  { atom ~ (bin_op ~ atom)* }
atom       = _{ unary_op? ~ primary }
bin_op     = _{ add | sub | mult | div | eq | neq | geq | gt | leq | lt | and | or }
unary_op   = _{ neg | not }
add        =  { "+" }
sub        =  { "-" }
mult       =  { "*" }
div        =  { "/" }
eq         =  { "==" }
neq        =  { "!=" }
gt         =  { ">" }
geq        =  { ">=" }
lt         =  { "<" }
leq        =  { "<=" }
and        =  { "&&" }
or         =  { "||" }
not        =  { "!" }
neg        =  { "-" }

variable_def = { "let" ~ ident ~ (":" ~ type)? ~ "=" ~ expression }

function_def = { "fun" ~ ident ~ "(" ~ params_list? ~ ")" ~ ("->" ~ type)? ~ block }
params_list  = { param ~ ("," ~ param)* }
param        = { ident ~ ":" ~ type }

// Types
type = { primitive_type }

primitive_type = { "string" | "int" | "float" | "bool" }
